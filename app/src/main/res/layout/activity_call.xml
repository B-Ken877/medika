<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <FrameLayout
        android:id="@+id/remoteVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/localVideoContainer"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="#333"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="60dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
        <TextView
            android:id="@+id/callStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connexion..."
            android:textColor="#ffffff"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/callTimerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#aaaaff"
            android:textSize="28sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="32dp">
        <ImageButton
            android:id="@+id/btnMute"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="24dp"
            android:background="@android:color/transparent"
            android:contentDescription="Mute"
            android:src="@android:drawable/ic_lock_silent_mode" />
        <ImageButton
            android:id="@+id/btnSpeaker"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="24dp"
            android:background="@android:color/transparent"
            android:contentDescription="Speaker"
            android:src="@android:drawable/ic_lock_silent_mode_off" />
        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="24dp"
            android:background="@android:color/transparent"
            android:contentDescription="Camera"
            android:src="@android:drawable/ic_menu_camera"
            android:visibility="gone" />
        <ImageButton
            android:id="@+id/btnHangup"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="#cc2222"
            android:contentDescription="Hang up"
            android:padding="8dp"
            android:src="@android:drawable/ic_delete" />
    </LinearLayout>
</FrameLayout>
