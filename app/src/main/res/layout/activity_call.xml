<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB">

    <!-- ===== Remote Video (full-screen background layer) ===== -->
    <FrameLayout
        android:id="@+id/remoteVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ===== Local Video (PIP, top-end corner) ===== -->
    <FrameLayout
        android:id="@+id/localVideoContainer"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginStart="16dp"
        android:layout_marginTop="68dp"
        android:layout_marginEnd="16dp"
        android:background="#1F2937"
        android:visibility="gone" />

    <!-- ===== Top Bar (56dp, dark-green) ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="#0D7A35"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <!-- Back / Close button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Fermer"
            android:padding="8dp"
            android:src="@drawable/ic_close" />

        <!-- Centered title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Appel en cours"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Timer (top-right) -->
        <TextView
            android:id="@+id/callTimerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ===== Center Info Panel ===== -->
    <LinearLayout
        android:id="@+id/callInfoPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Avatar Circle -->
        <TextView
            android:id="@+id/avatarInitial"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_circle_avatar"
            android:gravity="center"
            android:text="D"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold" />

        <!-- Remote User Name -->
        <TextView
            android:id="@+id/remoteUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#1F2937"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Calling Status -->
        <TextView
            android:id="@+id/callStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Connexion..."
            android:textColor="#9CA3AF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ===== Bottom Call Controls ===== -->
    <LinearLayout
        android:id="@+id/callControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="100dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Mute Mic -->
        <ImageButton
            android:id="@+id/btnMute"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="Muet"
            android:padding="14dp"
            android:src="@drawable/ic_mic" />

        <!-- Toggle Video -->
        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="Caméra"
            android:padding="14dp"
            android:src="@drawable/ic_videocam"
            android:visibility="gone" />

        <!-- Speaker -->
        <ImageButton
            android:id="@+id/btnSpeaker"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_circle_control"
            android:contentDescription="Haut-parleur"
            android:padding="14dp"
            android:src="@drawable/ic_speaker" />

        <!-- End Call (larger, red) -->
        <ImageButton
            android:id="@+id/btnHangup"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_red"
            android:contentDescription="Raccrocher"
            android:padding="14dp"
            android:src="@drawable/ic_call_end" />
    </LinearLayout>

</FrameLayout>